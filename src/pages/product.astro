---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';

const pipeline = [
	{ step: 'Parse', body: 'Schema Parser ingests source HL7v2 segments, FHIR resources, or C-CDA templates into a canonical representation.' },
	{ step: 'Plan', body: 'Mapping Planner proposes field mappings grounded in SNOMED CT, LOINC, ICD-10-CM, and RxNorm embeddings, with a calibrated confidence score per mapping.' },
	{ step: 'Generate', body: 'Code Generator produces the transformer and filter code for the target channel.' },
	{ step: 'Validate', body: 'Generated code is executed in a sandbox against sample messages; a structured error trace is produced.' },
	{ step: 'Fix', body: 'The Fixer agent conditions on the error trace to correct the generation — up to 5 iterations.' },
	{ step: 'Approve', body: 'Low-risk changes auto-deploy. High-risk changes (unit conversions, demographic mappings, medication codes) require human approval, regardless of AI confidence.' },
];

const capabilities = [
	{
		title: 'Agentic AI channel generation',
		body: 'Time-to-production for standard HL7v2 → FHIR R4 integrations drops from 2–4 weeks of developer effort to under 5 minutes.',
	},
	{
		title: 'Self-healing integration',
		body: 'Continuously monitors for schema drift, FHIR CapabilityStatement changes, new Z-segments, and terminology updates — and regenerates and validates fixes automatically.',
	},
	{
		title: 'Full connector parity',
		body: 'HL7v2/MLLP, FHIR R4 REST, DICOM (C-STORE, C-FIND, DICOMweb), HTTP/REST, SOAP, Kafka, JDBC, File, FTP/SFTP, JMS, S3, ASTM, WebSocket, Email — 14 connectors in total.',
	},
	{
		title: 'Real-time operations dashboard',
		body: 'Live channel health, throughput graphs, latency percentiles (p50/p95/p99), queue depth, error analytics, and interactive message-flow topology.',
	},
	{
		title: 'Git-based versioning & collaboration',
		body: 'Channels, transformers, and filters are first-class Git artifacts — branching, pull requests, code review, and environment promotion (dev → staging → prod).',
	},
	{
		title: 'RBAC & compliance',
		body: 'Enterprise SSO (SAML 2.0, OIDC, LDAP/AD via Keycloak), granular custom roles, channel-level access scoping, immutable audit trails, PHI-access logging.',
	},
	{
		title: 'Intelligent alerting',
		body: '10+ alert types — channel down, error-rate spike, latency degradation, queue backlog, schema mismatch, certificate expiry — via Slack, Teams, PagerDuty, webhooks, email, SMS.',
	},
	{
		title: 'Natural language operations',
		body: '"Show me all channels with errors in the last hour." Operators query channel state in plain English; the LLM planner translates to structured queries and proposes remediation.',
	},
];

const connectors = [
	'HL7v2 / MLLP', 'FHIR R4 REST', 'DICOM', 'HTTP / HTTPS', 'SOAP', 'Apache Kafka',
	'JDBC', 'File', 'FTP / SFTP', 'JMS', 'Amazon S3', 'ASTM (lab analyzers)', 'WebSocket', 'Email',
];
---

<Layout title="Product">
	<section class="mx-auto max-w-6xl px-6 pt-16 pb-12">
		<Eyebrow text="Product" />
		<h1 class="max-w-3xl text-4xl font-bold tracking-tight text-white sm:text-5xl">
			One agentic pipeline. Production-grade integration channels.
		</h1>
		<p class="mt-6 max-w-2xl text-lg text-slate-400">
			A deterministic, auditable state machine — not a free-form multi-agent chat — moves every channel
			from raw schema to a deployed, validated integration.
		</p>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto max-w-6xl px-6 py-16">
			<h2 class="text-2xl font-bold text-white">The agentic pipeline</h2>
			<div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					pipeline.map((p, i) => (
						<div class="rounded-2xl border border-white/10 bg-slate-950 p-6">
							<span class="text-xs font-semibold text-cyan-400">STEP {i + 1}</span>
							<h3 class="mt-2 text-lg font-semibold text-white">{p.step}</h3>
							<p class="mt-2 text-sm text-slate-400">{p.body}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-20">
		<h2 class="text-2xl font-bold text-white">Eight capabilities that redefine the category</h2>
		<div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
			{
				capabilities.map((c) => (
					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
						<h3 class="text-base font-semibold text-white">{c.title}</h3>
						<p class="mt-2 text-sm text-slate-400">{c.body}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto max-w-6xl px-6 py-16">
			<h2 class="text-2xl font-bold text-white">Connector breadth</h2>
			<p class="mt-2 max-w-2xl text-slate-400">
				Native support for every major healthcare integration protocol — matching legacy engine breadth
				while adding cloud-native connectors.
			</p>
			<div class="mt-8 flex flex-wrap gap-3">
				{
					connectors.map((c) => (
						<span class="rounded-full border border-white/10 bg-slate-950 px-4 py-2 text-sm text-slate-300">
							{c}
						</span>
					))
				}
			</div>
		</div>
	</section>
</Layout>
