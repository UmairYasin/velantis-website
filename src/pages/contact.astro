---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';
---

<Layout title="Contact">
	<section class="mx-auto max-w-3xl px-6 py-24 text-center">
		<Eyebrow text="Investors" />
		<h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">Let's talk.</h1>
		<p class="mt-6 text-lg text-slate-400">
			Reach out for the full investor deck, a product walkthrough, or to discuss the Q3 2026 design-partner
			pilot.
		</p>
		<a
			href="mailto:umairyasin6@gmail.com?subject=Velantis%20-%20Investor%20Inquiry"
			class="mt-10 inline-block rounded-full bg-cyan-400 px-8 py-4 text-base font-semibold text-slate-950 transition hover:bg-cyan-300"
		>
			Email umairyasin6@gmail.com
		</a>
		<p class="mt-6 text-sm text-slate-500">We typically respond within 1–2 business days.</p>
	</section>
</Layout>
