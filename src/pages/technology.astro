---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';

const services = [
	{ name: 'Channel Runtime', body: 'Executes deployed channels. Stateless, horizontally scalable, pluggable connector SPI.' },
	{ name: 'AI Agent Service', body: 'Hosts the Schema Parser, Mapping Planner, Code Generator, Validator, and Fixer agents on LangChain4j / Spring AI.' },
	{ name: 'LLM Gateway', body: 'Model-agnostic façade across Anthropic, OpenAI, and self-hosted Llama/Mistral — prompt caching, rate limiting, cost accounting, provider failover.' },
	{ name: 'RBAC Service', body: 'Keycloak-backed SAML/OIDC/LDAP federation issuing JWTs with granular scopes.' },
	{ name: 'Audit Service', body: 'Append-only, cryptographically chained event store. Every PHI access and AI-generated artifact is recorded.' },
	{ name: 'Alerting Service', body: 'Rule engine with multi-channel notification fan-out and escalation policy evaluation.' },
	{ name: 'Config Service', body: 'Git-native configuration store — channels, transformers, and filters committed with PR-based change control.' },
	{ name: 'API Gateway', body: 'Spring Cloud Gateway enforcing auth, rate limits, and request tracing.' },
];

const standards = [
	{ name: 'HL7 v2.x (2.3–2.9)', body: 'Ingestion and egress via MLLP. An internal parser produces a canonical segment tree consumed directly by the Mapping Planner.' },
	{ name: 'HL7 FHIR R4 / R4B', body: 'Bidirectional — a destination format for v2-liberated data, and a source for modern EHR APIs (Epic, Cerner/Oracle Health, Meditech). CapabilityStatement-aware.' },
	{ name: 'HL7 CDA / C-CDA', body: 'Ingested for care-summary exchange with HIEs. The Schema Parser extracts medication, problem, and allergy sections for FHIR mapping.' },
	{ name: 'Terminology (SNOMED CT, LOINC, ICD-10, RxNorm, UCUM)', body: 'Terminology-aware embeddings resolve source codes, flag orphans, and propose canonical codes with provenance.' },
];

const aiApproaches = [
	{ name: 'Generative AI (LLMs)', body: 'Claude, GPT, and self-hosted Llama/Mistral drive the agent pipeline — large frontier models for code generation, smaller distilled models for structured extraction.' },
	{ name: 'Retrieval-augmented generation', body: 'Terminology corpora are indexed as embeddings; the Mapping Planner retrieves nearest concepts per field, grounding proposals and cutting code-mapping hallucination from ~18% to under 2%.' },
	{ name: 'Agentic orchestration', body: 'A deterministic state machine (Parse → Plan → Generate → Validate → Fix → Approve) — not free-form multi-agent chat — so every transition is auditable.' },
	{ name: 'Program synthesis + execution validation', body: 'Generated code runs in a sandbox against sample messages; the Validator’s error trace conditions the Fixer’s next attempt, capped at 5 iterations.' },
	{ name: 'Classical ML for operations', body: 'Anomaly detection on throughput, latency, and error rate uses seasonal ARIMA and tree-based classifiers — the right tool for high-frequency time series, not an LLM.' },
	{ name: 'Constrained NLP for operations', body: 'Operator queries are parsed by a constrained-decoding LLM into structured queries against metrics and audit stores — deliberately not free-form SQL generation.' },
];
---

<Layout title="Technology">
	<section class="mx-auto max-w-6xl px-6 pt-16 pb-12">
		<Eyebrow text="Technology" />
		<h1 class="max-w-3xl text-4xl font-bold tracking-tight text-white sm:text-5xl">
			Standards-first architecture, built for regulated environments.
		</h1>
		<p class="mt-6 max-w-2xl text-lg text-slate-400">
			Java 21 on Spring Boot 3.x, orchestrated by Kubernetes, with an Angular 21 frontend and a
			model-agnostic LLM gateway. Every channel's semantic contract is an HL7 standard, not a proprietary
			object model — so customers are never locked in.
		</p>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto max-w-6xl px-6 py-16">
			<h2 class="text-2xl font-bold text-white">Core services</h2>
			<div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
				{
					services.map((s) => (
						<div class="rounded-2xl border border-white/10 bg-slate-950 p-5">
							<h3 class="text-sm font-semibold text-white">{s.name}</h3>
							<p class="mt-2 text-xs text-slate-400">{s.body}</p>
						</div>
					))
				}
			</div>
			<p class="mt-8 text-sm text-slate-500">
				Data plane: PostgreSQL (metadata, audit), Redis (channel state, cache), Kafka (event bus,
				high-volume brokering). Observability: OpenTelemetry, ELK, Prometheus/Grafana. Deployment models:
				single-tenant SaaS, multi-tenant SaaS, on-premise Kubernetes, and hybrid for data sovereignty.
			</p>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-20">
		<h2 class="text-2xl font-bold text-white">HL7 standards used</h2>
		<div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
			{
				standards.map((s) => (
					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
						<h3 class="text-base font-semibold text-white">{s.name}</h3>
						<p class="mt-2 text-sm text-slate-400">{s.body}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto max-w-6xl px-6 py-20">
			<h2 class="text-2xl font-bold text-white">AI approach</h2>
			<p class="mt-2 max-w-2xl text-slate-400">
				Velantis combines multiple AI paradigms, each applied where it performs best — not a single model
				used as a hammer for every problem.
			</p>
			<div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-2">
				{
					aiApproaches.map((a) => (
						<div class="rounded-2xl border border-white/10 bg-slate-950 p-6">
							<h3 class="text-base font-semibold text-white">{a.name}</h3>
							<p class="mt-2 text-sm text-slate-400">{a.body}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-20">
		<h2 class="text-2xl font-bold text-white">Cost & scalability profile</h2>
		<div class="mt-6 grid grid-cols-1 gap-6 sm:grid-cols-3">
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
				<p class="text-2xl font-bold text-white">$0.15–$0.80</p>
				<p class="mt-2 text-sm text-slate-400">LLM inference cost per generated channel</p>
			</div>
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
				<p class="text-2xl font-bold text-white">~$40k</p>
				<p class="mt-2 text-sm text-slate-400">Replacement labor cost per hand-coded channel — ROI after channel one</p>
			</div>
			<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
				<p class="text-2xl font-bold text-white">1,000+ msg/s</p>
				<p class="mt-2 text-sm text-slate-400">Target throughput per channel instance, runs on a 4-node / 16 vCPU cluster</p>
			</div>
		</div>
	</section>
</Layout>
