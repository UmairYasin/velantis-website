---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';

const compliance = [
	{ name: 'HIPAA', body: 'Designed to execute under a BAA. Every PHI touchpoint logged with actor, resource, and payload hash. Minimum-necessary enforcement via channel-level scoping.' },
	{ name: 'SOC 2 Type II', body: 'Annual certification target. Compliance documentation is generated directly from the audit stream, so attestation is continuous rather than point-in-time.' },
	{ name: 'GDPR', body: 'Data-subject access and erasure implemented at the channel-data-store level. PII/PHI tagged at ingestion so erasure requests run without full-table scans.' },
	{ name: 'EU AI Act', body: 'Architecture designed around "high-risk" AI system obligations — documented model provenance, auditable deterministic orchestration, human-in-the-loop gates, full incident logging.' },
	{ name: 'State regulations', body: 'Data-classification and audit trail satisfy stricter state regimes (CCPA/CMIA, NY SHIELD) without per-tenant customization.' },
	{ name: 'ISO 27001 / HITRUST CSF', body: 'On roadmap, alongside the on-premise HITRUST CSF deployment track.' },
];

const security = [
	{
		group: 'Identity & access',
		items: [
			'Enterprise SSO via SAML 2.0, OIDC, LDAP/AD through Keycloak',
			'JWT-based authorization at every API gateway and service boundary',
			'Five built-in roles plus custom role builder; channel-level access scoping',
			'MFA required for privileged roles',
		],
	},
	{
		group: 'Data protection',
		items: [
			'TLS 1.2+ on every network hop, including mutual TLS service-to-service',
			'AES-256 encryption at rest across PostgreSQL, Redis, Kafka, S3',
			'PHI field-level tagging with redaction in logs and AI-agent prompts',
			'Key management via cloud KMS or HashiCorp Vault on-premise',
		],
	},
	{
		group: 'LLM-specific privacy',
		items: [
			'Zero-retention provider contracts for external LLMs',
			'Prompt-level PHI scrubbing before any external LLM call',
			'Self-hosted LLM option (Llama, Mistral) for perimeter-locked customers',
			'No training on customer PHI — fine-tuning is tenant-scoped and opt-in',
		],
	},
	{
		group: 'Audit & operations',
		items: [
			'Append-only, cryptographically chained audit trail',
			'SIEM integration (Splunk, Sentinel, Elastic) via standardized event streams',
			'Automated alerting on privilege escalation and bulk PHI access',
			'Signed, scanned container images with SLSA-level build attestations',
		],
	},
];
---

<Layout title="Security & Compliance">
	<section class="mx-auto max-w-6xl px-6 pt-16 pb-12">
		<Eyebrow text="Security & Compliance" />
		<h1 class="max-w-3xl text-4xl font-bold tracking-tight text-white sm:text-5xl">
			Built for the regulatory bar healthcare AI actually has to clear.
		</h1>
		<p class="mt-6 max-w-2xl text-lg text-slate-400">
			High-risk mappings cannot auto-deploy regardless of AI confidence — a deliberate ceiling on AI
			authority, enforced by a risk classifier and a named human approver recorded in the audit trail.
		</p>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto max-w-6xl px-6 py-16">
			<h2 class="text-2xl font-bold text-white">Compliance posture</h2>
			<div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					compliance.map((c) => (
						<div class="rounded-2xl border border-white/10 bg-slate-950 p-6">
							<h3 class="text-base font-semibold text-white">{c.name}</h3>
							<p class="mt-2 text-sm text-slate-400">{c.body}</p>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-20">
		<h2 class="text-2xl font-bold text-white">Security architecture</h2>
		<div class="mt-8 grid grid-cols-1 gap-8 md:grid-cols-2">
			{
				security.map((group) => (
					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
						<h3 class="text-base font-semibold text-white">{group.group}</h3>
						<ul class="mt-4 space-y-2">
							{group.items.map((item) => (
								<li class="flex gap-2 text-sm text-slate-400">
									<span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-cyan-400" />
									{item}
								</li>
							))}
						</ul>
					</div>
				))
			}
		</div>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto max-w-6xl px-6 py-16">
			<h2 class="text-2xl font-bold text-white">Three deliberate ethical commitments</h2>
			<div class="mt-8 grid grid-cols-1 gap-6 md:grid-cols-3">
				<div class="rounded-2xl border border-white/10 bg-slate-950 p-6">
					<h3 class="text-base font-semibold text-white">Human-in-the-loop by default</h3>
					<p class="mt-2 text-sm text-slate-400">Clinical-risk mappings cannot auto-deploy regardless of AI confidence.</p>
				</div>
				<div class="rounded-2xl border border-white/10 bg-slate-950 p-6">
					<h3 class="text-base font-semibold text-white">Confidence transparency, not marketing</h3>
					<p class="mt-2 text-sm text-slate-400">Calibrated, not optimistic, confidence scores — we reject UX that encourages ignoring low-confidence warnings.</p>
				</div>
				<div class="rounded-2xl border border-white/10 bg-slate-950 p-6">
					<h3 class="text-base font-semibold text-white">Built to be replaceable</h3>
					<p class="mt-2 text-sm text-slate-400">Channels are portable because their contract is an HL7 standard, not a proprietary model — it's in our interest to keep earning the seat.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
