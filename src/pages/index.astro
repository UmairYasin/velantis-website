---
import Layout from '../layouts/Layout.astro';
import Eyebrow from '../components/Eyebrow.astro';

const stats = [
	{ value: '2–4 wks → <5 min', label: 'Time to build a standard HL7v2 → FHIR R4 channel' },
	{ value: '$180k–240k', label: 'Fully-loaded cost per integration engineer, per year' },
	{ value: '50–300', label: 'Live interfaces a typical hospital runs and maintains' },
];

const highlights = [
	{
		title: 'Agentic channel generation',
		body: 'A multi-agent pipeline — Schema Parser, Mapping Planner, Code Generator, Validator, Fixer — builds production channels end-to-end, grounded in SNOMED CT, LOINC, ICD-10-CM, and RxNorm.',
	},
	{
		title: 'Self-healing integration',
		body: 'Schema drift, FHIR CapabilityStatement changes, and terminology updates are detected and repaired automatically — eliminating the silent channel failures that plague clinical environments.',
	},
	{
		title: 'Git-native & auditable',
		body: 'Channels, transformers, and filters are first-class Git artifacts with branching, PR review, and environment promotion. Every AI decision is logged and reviewable by compliance.',
	},
];
---

<Layout title="Home">
	<section class="mx-auto max-w-6xl px-6 pt-20 pb-24 text-center">
		<Eyebrow text="Agentic AI · Healthcare Integration" />
		<h1 class="mx-auto max-w-4xl text-4xl font-bold tracking-tight text-white sm:text-6xl">
			The engine is the agent.
			<span class="text-cyan-400">The developer is the reviewer.</span>
		</h1>
		<p class="mx-auto mt-6 max-w-2xl text-lg text-slate-400">
			Velantis is the first agentic AI-native healthcare integration engine — it generates, validates, and
			self-heals HL7v2, FHIR R4, and CDA integration channels autonomously, replacing weeks of hand-coded
			interface work with minutes of AI-assisted review.
		</p>
		<div class="mt-10 flex flex-wrap items-center justify-center gap-4">
			<a
				href="/product"
				class="rounded-full bg-cyan-400 px-6 py-3 text-sm font-semibold text-slate-950 transition hover:bg-cyan-300"
			>
				See the product →
			</a>
			<a
				href="/contact"
				class="rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-white transition hover:border-white/40"
			>
				Talk to us
			</a>
		</div>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto grid max-w-6xl grid-cols-1 gap-8 px-6 py-16 sm:grid-cols-3">
			{
				stats.map((stat) => (
					<div class="text-center">
						<p class="text-3xl font-bold text-white sm:text-4xl">{stat.value}</p>
						<p class="mt-2 text-sm text-slate-400">{stat.label}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="mx-auto max-w-6xl px-6 py-24">
		<div class="max-w-2xl">
			<Eyebrow text="Why Velantis is new" />
			<h2 class="text-3xl font-bold text-white sm:text-4xl">
				Legacy interface engines treat the developer as the intelligent agent.
			</h2>
			<p class="mt-4 text-slate-400">
				Mirth Connect, Rhapsody, Cloverleaf, and InterSystems IRIS are canvases — every transformer and filter
				is hand-coded by a specialist. Velantis inverts the model: the engine builds and maintains the
				integration; the integration team reviews and approves.
			</p>
		</div>
		<div class="mt-12 grid grid-cols-1 gap-8 md:grid-cols-3">
			{
				highlights.map((item) => (
					<div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6">
						<h3 class="text-lg font-semibold text-white">{item.title}</h3>
						<p class="mt-3 text-sm text-slate-400">{item.body}</p>
					</div>
				))
			}
		</div>
	</section>

	<section class="border-t border-white/10 bg-white/[0.02]">
		<div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 py-16 text-center md:flex-row md:text-left">
			<div>
				<h2 class="text-2xl font-bold text-white">Pre-pilot today. Design partners in Q3 2026.</h2>
				<p class="mt-2 text-slate-400">
					Seven of nine backend services are live. We're selecting 3–5 design-partner hospital systems now.
				</p>
			</div>
			<a
				href="/roadmap"
				class="shrink-0 rounded-full border border-white/15 px-6 py-3 text-sm font-semibold text-white transition hover:border-white/40"
			>
				View the roadmap →
			</a>
		</div>
	</section>
</Layout>
